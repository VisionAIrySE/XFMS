# XFMS client — environment configuration
# Copy this file to `.env` for local dev. `.env` is gitignored and
# never leaves your machine. Or just `export` these in your shell.

# Required: your XFMS access key. Identifies you to the hosted API
# for rate limiting + the Xpansion mailing list. Request one at:
# https://xpansion.dev/xfms/get-started
XFMS_API_KEY=

# Required: your OpenRouter key. XFMS makes a small LLM call per
# pick to infer which benchmarks matter for your stated purpose.
# That call goes through your OpenRouter account (BYOK), so the
# inference cost stays with you. ~$0.001 per pick. Sign up at:
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the XFMS endpoint URL. Defaults to the hosted
# instance. Useful only if you're running your own engine instance.
# XFMS_BASE_URL=https://xfms.vercel.app
